QMainWindow {
    background-color: #f5f6fa;
}

QLabel {
    color: #2c3e50;
}

QPushButton {
    background-color: #3498db;
    color: white;
    padding: 8px;
    border-radius: 6px;
}

QPushButton:hover {
    background-color: #2980b9;
}

QFrame {
    background-color: white;
    border-radius: 10px;
    padding: 10px;
    border: 1px solid #dcdde1;
}

QTableWidget  {
    color: black;
}